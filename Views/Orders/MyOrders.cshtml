@using BarberHub.Web.Domain.Entities
@model List<OrderListItemDto>
@{
    ViewData["Title"] = "My Orders";
}

<div class="d-flex justify-content-between align-items-end mb-3 flex-wrap gap-2">
    <div>
        <h2 class="section-title">My Orders</h2>
        <p class="section-subtitle mb-0">Order history and status.</p>
    </div>
    <a asp-controller="Products" asp-action="Index" class="btn btn-light"><i class="bi bi-bag me-1"></i> Shop more</a>
</div>

@if (!Model.Any())
{
    <div class="bh-card p-5 text-center">
        <div class="stat-icon coral mx-auto mb-3" style="width:64px;height:64px;font-size:1.6rem;"><i class="bi bi-receipt"></i></div>
        <h5>No orders yet</h5>
        <p class="text-muted mb-3">Place your first order to see it here.</p>
        <a asp-controller="Products" asp-action="Index" class="btn btn-primary">Browse products</a>
    </div>
}
else
{
    <div class="d-flex flex-column gap-3">
        @foreach (var o in Model)
        {
            <div class="bh-card p-4">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                    <div>
                        <h6 class="mb-1">Order #@o.OrderNumber</h6>
                        <div class="small text-muted"><i class="bi bi-calendar3 me-1"></i>Placed @o.CreatedAt.ToString("MMM dd, yyyy · HH:mm")</div>
                    </div>
                    <div class="text-end">
                        <div class="fw-bold fs-5 text-coral">₹@o.TotalAmount</div>
                        <div class="d-flex gap-1 justify-content-end flex-wrap">
                            @if (o.PaymentMethod == PaymentMethod.CashOnDelivery)
                            {
                                <span class="badge bg-warning"><i class="bi bi-cash me-1"></i>COD</span>
                            }
                            <span class="badge @(o.Status == OrderStatus.Paid ? "bg-success" : o.Status == OrderStatus.Pending ? "bg-warning" : "bg-secondary")">@o.Status</span>
                        </div>
                    </div>
                </div>
                <hr style="border-color:var(--bh-border);" />
                <div class="d-flex flex-column gap-2">
                    @foreach (var item in o.Items)
                    {
                        <div class="d-flex justify-content-between small">
                            <span>@item.ProductName <span class="text-muted">× @item.Quantity</span></span>
                            <span class="fw-semibold">₹@item.LineTotal</span>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}
