@model OrderListItemDto
@{ ViewData["Title"] = "Order Confirmed"; }

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="bh-card p-5 text-center" style="background:linear-gradient(135deg, #fff 0%, #dcfce7 100%);">
            <div class="stat-icon emerald mx-auto mb-3" style="width:84px;height:84px;font-size:2.4rem;"><i class="bi bi-check2-circle"></i></div>
            <h2 class="mb-2">Thank you!</h2>
            <p class="text-muted">Your order has been placed successfully.</p>

            <div class="bh-card p-4 mt-4 mb-4 text-start" style="background:#fff;">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Order Number</span>
                    <strong>@Model.OrderNumber</strong>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-muted">Total</span>
                    <strong class="text-coral">₹@Model.TotalAmount</strong>
                </div>
            </div>

            <p class="small text-muted">Payment confirmation may take a few seconds to update.</p>
            <div class="d-flex flex-wrap gap-2 justify-content-center mt-3">
                <a asp-action="MyOrders" class="btn btn-primary">View My Orders</a>
                <a asp-controller="Products" asp-action="Index" class="btn btn-outline-secondary">Continue Shopping</a>
            </div>
        </div>
    </div>
</div>
