@model List<UserListItemDto>
@{ ViewData["Title"] = "Users"; }

<div class="d-flex justify-content-between align-items-end mb-3 flex-wrap gap-2">
    <div>
        <h2 class="section-title">All Users</h2>
        <p class="section-subtitle mb-0">Customers registered on the platform.</p>
    </div>
    <span class="badge bg-light text-dark px-3 py-2"><i class="bi bi-people me-1"></i>@Model.Count users</span>
</div>

@if (!Model.Any())
{
    <div class="bh-card p-5 text-center">
        <div class="stat-icon sky mx-auto mb-3" style="width:64px;height:64px;font-size:1.6rem;"><i class="bi bi-people"></i></div>
        <h5>No users yet</h5>
        <p class="text-muted mb-0">Users who register will appear here.</p>
    </div>
}
else
{
    <div class="bh-card p-0 overflow-hidden">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>City</th>
                        <th>Joined</th>
                        <th class="pe-4">Status</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var u in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center gap-2">
                                <div class="bh-avatar" style="width:36px;height:36px;font-size:.85rem;">@(string.IsNullOrEmpty(u.FullName) ? "U" : u.FullName.Substring(0,1).ToUpper())</div>
                                <strong>@u.FullName</strong>
                            </div>
                        </td>
                        <td class="text-muted">@u.Email</td>
                        <td class="text-muted">@u.PhoneNumber</td>
                        <td>@u.City</td>
                        <td class="text-muted">@u.CreatedAt.ToString("MMM dd, yyyy")</td>
                        <td class="pe-4"><span class="badge @(u.IsActive ? "bg-success" : "bg-secondary")">@(u.IsActive ? "Active" : "Inactive")</span></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}
