@model BarberHub.Web.Features.Admin.AdminCreateBookingDto
@{ ViewData["Title"] = "Book for Customer"; }

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="d-flex justify-content-between align-items-end mb-3 flex-wrap gap-2">
            <div>
                <h2 class="section-title">Book for a Customer</h2>
                <p class="section-subtitle mb-0">Create a confirmed appointment on a customer's behalf.</p>
            </div>
            <a asp-controller="Bookings" asp-action="Manage" class="btn btn-light"><i class="bi bi-arrow-left me-1"></i>Back</a>
        </div>

        <div class="bh-card p-4 p-md-5">
            <partial name="_ValidationSummary" />
            <form asp-action="CreateBooking" method="post">
                @Html.AntiForgeryToken()
                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="UserId" class="form-label"></label>
                        <select asp-for="UserId" asp-items="(IEnumerable<SelectListItem>)ViewBag.Users" class="form-select">
                            <option value="">-- Select customer --</option>
                        </select>
                        <small class="text-muted">Don't see them? <a asp-action="AddUser" class="text-coral fw-semibold">Add a new customer</a> first.</small>
                    </div>
                    <div class="col-12">
                        <label asp-for="ServiceId" class="form-label"></label>
                        <select asp-for="ServiceId" asp-items="(IEnumerable<SelectListItem>)ViewBag.Services" class="form-select">
                            <option value="">-- Select service --</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="AppointmentDate" class="form-label"></label>
                        <input asp-for="AppointmentDate" type="date" class="form-control" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="StartTime" class="form-label"></label>
                        <input asp-for="StartTime" type="time" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label asp-for="Notes" class="form-label"></label>
                        <textarea asp-for="Notes" class="form-control" rows="2" placeholder="Any preferences or special notes..."></textarea>
                    </div>
                </div>
                <div class="bh-card p-3 mt-4" style="background:var(--bh-bg);">
                    <small class="text-muted"><i class="bi bi-info-circle me-1"></i>This booking will be auto-confirmed (status: Accepted) since you're creating it directly.</small>
                </div>
                <div class="d-flex gap-2 mt-3">
                    <button class="btn btn-primary"><i class="bi bi-calendar-check me-1"></i>Confirm Booking</button>
                    <a asp-controller="Bookings" asp-action="Manage" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
