@model ProductListItemDto
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@{ ViewData["Title"] = Model.Name; }

<div class="row g-4">
    <div class="col-lg-6">
        <div class="bh-card p-3">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" class="img-fluid rounded" style="width:100%;aspect-ratio:1/1;object-fit:cover;border-radius:12px;" />
            }
            else
            {
                <div class="d-flex align-items-center justify-content-center rounded" style="aspect-ratio:1/1;background:var(--bh-bg);border-radius:12px;">
                    <i class="bi bi-image text-muted" style="font-size:5rem;"></i>
                </div>
            }
        </div>
    </div>
    <div class="col-lg-6">
        <div class="bh-card p-4 p-md-5">
            <div class="d-flex align-items-center gap-2 mb-2">
                <span class="badge bg-light text-dark">@Model.Category</span>
                <span class="text-muted small">by @Model.BarberName</span>
            </div>
            <h2 class="mb-3">@Model.Name</h2>
            <p class="text-muted">@Model.Description</p>

            <div class="my-4">
                @if (Model.DiscountPercentage.HasValue && Model.DiscountPercentage > 0)
                {
                    <div class="d-flex align-items-baseline gap-3 flex-wrap">
                        <span class="price-final" style="font-size:2.25rem;">₹@Model.EffectivePrice</span>
                        <span class="price-original" style="font-size:1.1rem;">₹@Model.Price</span>
                        <span class="badge bg-danger" style="font-size:.85rem;">@Model.DiscountPercentage% OFF</span>
                    </div>
                    <div class="price-save mt-1">You save ₹@(Model.Price - Model.EffectivePrice)</div>
                }
                else
                {
                    <span class="price-final" style="font-size:2.25rem;">₹@Model.Price</span>
                }
            </div>

            <div class="@(Model.StockQuantity > 0 ? "text-success" : "text-danger") small fw-semibold mb-4">
                <i class="bi @(Model.StockQuantity > 0 ? "bi-check-circle-fill" : "bi-x-circle-fill") me-1"></i>
                @(Model.StockQuantity > 0 ? $"In stock — {Model.StockQuantity} available" : "Out of stock")
            </div>

            @if (SignInManager.IsSignedIn(User) && User.IsInRole(AppRoles.User) && Model.StockQuantity > 0)
            {
                <form asp-controller="Cart" asp-action="Add" method="post" class="d-flex gap-3 align-items-end flex-wrap">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@Model.Id" />
                    <div>
                        <label class="form-label">Quantity</label>
                        <input name="quantity" type="number" min="1" max="@Model.StockQuantity" value="1" class="form-control" style="width:110px" />
                    </div>
                    <button class="btn btn-primary btn-lg flex-grow-1"><i class="bi bi-bag-plus me-1"></i> Add to Cart</button>
                </form>
            }
            else if (!SignInManager.IsSignedIn(User))
            {
                <a asp-controller="Auth" asp-action="Login" class="btn btn-primary btn-lg">Sign in to purchase</a>
            }
        </div>
    </div>
</div>
