@model CreateProductDto
@{ ViewData["Title"] = "Add Product"; }

<div class="row justify-content-center">
    <div class="col-lg-8">
        <h2 class="section-title">Add Product</h2>
        <p class="section-subtitle">List a new item in your store.</p>

        <div class="bh-card p-4 p-md-5">
            <partial name="_ValidationSummary" />
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div class="row g-3">
                    <div class="col-md-8">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" placeholder="e.g. Premium Hair Wax" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Category" class="form-label"></label>
                        <input asp-for="Category" class="form-control" placeholder="e.g. Styling" />
                    </div>
                    <div class="col-12">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Describe the product, ingredients, and benefits..."></textarea>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Price" class="form-label">Price (₹)</label>
                        <input asp-for="Price" type="number" step="0.01" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="DiscountPercentage" class="form-label">Discount (%)</label>
                        <input asp-for="DiscountPercentage" type="number" step="0.01" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="StockQuantity" class="form-label"></label>
                        <input asp-for="StockQuantity" type="number" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label asp-for="Image" class="form-label"></label>
                        <input asp-for="Image" type="file" accept="image/*" class="form-control" />
                        <small class="text-muted">High-quality product image, ideally square.</small>
                    </div>
                </div>
                <div class="d-flex gap-2 mt-4">
                    <button class="btn btn-primary"><i class="bi bi-check2 me-1"></i> Create Product</button>
                    <a asp-action="Manage" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
