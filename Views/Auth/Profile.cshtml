@model EditProfileDto
@{
    ViewData["Title"] = "Profile";
}

<div class="row justify-content-center">
    <div class="col-lg-9">
        <h2 class="section-title">Edit Profile</h2>
        <p class="section-subtitle">Update your personal info and shop settings.</p>

        <div class="bh-card p-4 p-md-5">
            <partial name="_ValidationSummary" />
            <form asp-action="Profile" method="post" enctype="multipart/form-data">
                <div class="row g-4">
                    <div class="col-md-3 text-center">
                        @if (!string.IsNullOrEmpty(ViewBag.CurrentImage as string))
                        {
                            <img src="@ViewBag.CurrentImage" class="rounded-circle mb-2" style="width:130px;height:130px;object-fit:cover;border:4px solid #fff;box-shadow:var(--bh-shadow);" />
                        }
                        else
                        {
                            <div class="rounded-circle d-inline-flex align-items-center justify-content-center text-white mb-2" style="width:130px;height:130px;background:linear-gradient(135deg, var(--bh-primary), var(--bh-accent));font-size:3rem;">
                                <i class="bi bi-person"></i>
                            </div>
                        }
                        <input asp-for="ProfileImage" type="file" accept="image/*" class="form-control form-control-sm mt-2" />
                        <small class="text-muted">JPG/PNG up to 2MB</small>
                    </div>
                    <div class="col-md-9">
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label">Email</label>
                                <input value="@ViewBag.Email" class="form-control" disabled style="background:var(--bh-bg);" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="FullName" class="form-label"></label>
                                <input asp-for="FullName" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="PhoneNumber" class="form-label"></label>
                                <input asp-for="PhoneNumber" class="form-control" />
                            </div>
                        </div>
                    </div>

                    <div class="col-12"><hr class="my-1" style="border-color:var(--bh-border);" /></div>

                    <div class="col-md-6">
                        <label asp-for="City" class="form-label"></label>
                        <input asp-for="City" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Address" class="form-label"></label>
                        <input asp-for="Address" class="form-control" />
                    </div>
                    <input asp-for="Latitude" type="hidden" />
                    <input asp-for="Longitude" type="hidden" />
                    <div class="col-12">
                        <label class="form-label">Your location</label>
                        @{
                            ViewData["LocationLat"] = Model.Latitude;
                            ViewData["LocationLng"] = Model.Longitude;
                        }
                        <partial name="Maps/_LocationPicker" />
                    </div>

                    @if (User.IsInRole(AppRoles.Admin))
                    {
                        <div class="col-12"><hr class="my-1" style="border-color:var(--bh-border);" /></div>
                        <div class="col-12">
                            <h5 class="mb-0"><i class="bi bi-shop me-2 text-coral"></i>Barber Shop Settings</h5>
                        </div>
                        <div class="col-md-12">
                            <label asp-for="ShopName" class="form-label"></label>
                            <input asp-for="ShopName" class="form-control" />
                        </div>
                        <div class="col-md-12">
                            <label asp-for="ShopDescription" class="form-label"></label>
                            <textarea asp-for="ShopDescription" class="form-control" rows="2"></textarea>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="WeeklyHoliday" class="form-label"></label>
                            <select asp-for="WeeklyHoliday" class="form-select" asp-items="Html.GetEnumSelectList<DayOfWeek>()">
                                <option value="">-- none --</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="OpeningTime" class="form-label"></label>
                            <input asp-for="OpeningTime" type="time" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="ClosingTime" class="form-label"></label>
                            <input asp-for="ClosingTime" type="time" class="form-control" />
                        </div>
                    }
                </div>
                <div class="d-flex gap-2 mt-4">
                    <button class="btn btn-primary"><i class="bi bi-check2 me-1"></i> Save Changes</button>
                    <a asp-action="ChangePassword" class="btn btn-outline-secondary"><i class="bi bi-key me-1"></i> Change Password</a>
                </div>
            </form>
        </div>
    </div>
</div>
