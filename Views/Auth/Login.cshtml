@using BarberHub.Web.Shared.Config
@using Microsoft.Extensions.Options
@inject IOptions<FeatureFlags> FeatureFlagsOpt
@model LoginDto
@{
    ViewData["Title"] = "Login";
    var f = FeatureFlagsOpt.Value;
    var googleEnabled = f.GoogleLoginEnabled;
}

<div class="auth-shell">
    <div class="row g-0 auth-split w-100" style="max-width:1000px;">
        <div class="col-lg-5 d-none d-lg-flex auth-split-left">
            <div>
                <a class="bh-brand" asp-controller="Home" asp-action="Index" style="color:#fff;">
                    <span class="bh-brand-mark"><i class="bi bi-scissors"></i></span>
                    <span style="color:#fff;">Barber Hub</span>
                </a>
            </div>
            <div>
                <h2>Welcome back, friend.</h2>
                <p class="mt-3" style="color:rgba(255,255,255,.85);">Your next appointment, your favourite products, and your barber are just one tap away.</p>
            </div>
            <div style="color:rgba(255,255,255,.7);font-size:.85rem;">
                <i class="bi bi-shield-check me-1"></i> Secure & private — your data stays yours.
            </div>
        </div>
        <div class="col-lg-7 auth-split-right">
            <h3 class="mb-1">Sign in to your account</h3>
            <p class="text-muted mb-4">Enter your email or phone to continue.</p>
            <partial name="_ValidationSummary" />

            @if (googleEnabled)
            {
                <a asp-controller="GoogleAuth" asp-action="Start" class="btn btn-light w-100 mb-2 d-flex align-items-center justify-content-center gap-2"
                       style="border:1px solid var(--bh-border);">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 48 48"><path fill="#FFC107" d="M43.6 20.5h-1.9V20H24v8h11.3c-1.6 4.6-6 8-11.3 8-6.6 0-12-5.4-12-12s5.4-12 12-12c3.1 0 5.9 1.2 8 3.1l5.7-5.7C34 6.1 29.3 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20 20-8.9 20-20c0-1.3-.1-2.6-.4-3.5z" /><path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.6 16.1 19 13 24 13c3.1 0 5.9 1.2 8 3.1l5.7-5.7C34 6.1 29.3 4 24 4 16.3 4 9.7 8.3 6.3 14.7z" /><path fill="#4CAF50" d="M24 44c5.2 0 9.9-2 13.4-5.2l-6.2-5.2c-2 1.5-4.5 2.4-7.2 2.4-5.3 0-9.7-3.4-11.3-8.1l-6.5 5C9.6 39.6 16.3 44 24 44z" /><path fill="#1976D2" d="M43.6 20.5H24v8h11.3c-.8 2.3-2.3 4.2-4.2 5.5l6.2 5.2C40.9 36.6 44 31.1 44 24c0-1.3-.1-2.6-.4-3.5z" /></svg>
                    Continue with Google
                </a>
            }
            @if (googleEnabled)
            {
                <div class="d-flex align-items-center my-3" aria-hidden="true">
                    <div class="flex-grow-1" style="height:1px;background:var(--bh-border);"></div>
                    <span class="px-3 small text-muted">or with password</span>
                    <div class="flex-grow-1" style="height:1px;background:var(--bh-border);"></div>
                </div>
            }

            <form asp-action="Login" method="post">
                <input asp-for="ReturnUrl" type="hidden" />
                <div class="mb-3">
                    <label asp-for="EmailOrPhone" class="form-label">Email or phone</label>
                    <input asp-for="EmailOrPhone" class="form-control" placeholder="email@example.com or +91…" />
                    <span asp-validation-for="EmailOrPhone" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <div class="d-flex justify-content-between">
                        <label asp-for="Password" class="form-label">Password</label>
                        <a asp-action="ForgotPassword" class="small text-coral text-decoration-none">Forgot?</a>
                    </div>
                    <input asp-for="Password" class="form-control" placeholder="Enter your password" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <button class="btn btn-primary w-100 btn-lg">Sign In</button>
            </form>
            <div class="mt-4 text-center text-muted small">
                Don't have an account? <a asp-action="Register" class="text-coral text-decoration-none fw-semibold">Create one</a>
            </div>
        </div>
    </div>
</div>
