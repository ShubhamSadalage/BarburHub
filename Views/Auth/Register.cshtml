@using BarberHub.Web.Shared.Config
@using Microsoft.Extensions.Options
@inject IOptions<FeatureFlags> FF
@model RegisterDto
@{
    ViewData["Title"] = "Register";
    var googleEnabled = FF.Value.GoogleLoginEnabled;
}

<div class="auth-shell">
    <div class="auth-card" style="max-width:680px;">
        <div class="text-center mb-4">
            <a class="bh-brand justify-content-center" asp-controller="Home" asp-action="Index">
                <span class="bh-brand-mark"><i class="bi bi-scissors"></i></span>
                <span>Barber Hub</span>
            </a>
            <h3 class="mt-3 mb-1">Create your account</h3>
            <p class="text-muted">Join the community in under a minute.</p>
        </div>

        @if (googleEnabled)
        {
            <a asp-controller="GoogleAuth" asp-action="Start" class="btn btn-light w-100 mb-2 d-flex align-items-center justify-content-center gap-2"
                   style="border:1px solid var(--bh-border);">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 48 48"><path fill="#FFC107" d="M43.6 20.5h-1.9V20H24v8h11.3c-1.6 4.6-6 8-11.3 8-6.6 0-12-5.4-12-12s5.4-12 12-12c3.1 0 5.9 1.2 8 3.1l5.7-5.7C34 6.1 29.3 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20 20-8.9 20-20c0-1.3-.1-2.6-.4-3.5z" /><path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.6 16.1 19 13 24 13c3.1 0 5.9 1.2 8 3.1l5.7-5.7C34 6.1 29.3 4 24 4 16.3 4 9.7 8.3 6.3 14.7z" /><path fill="#4CAF50" d="M24 44c5.2 0 9.9-2 13.4-5.2l-6.2-5.2c-2 1.5-4.5 2.4-7.2 2.4-5.3 0-9.7-3.4-11.3-8.1l-6.5 5C9.6 39.6 16.3 44 24 44z" /><path fill="#1976D2" d="M43.6 20.5H24v8h11.3c-.8 2.3-2.3 4.2-4.2 5.5l6.2 5.2C40.9 36.6 44 31.1 44 24c0-1.3-.1-2.6-.4-3.5z" /></svg>
                Continue with Google
            </a>
            <div class="d-flex align-items-center my-3" aria-hidden="true">
                <div class="flex-grow-1" style="height:1px;background:var(--bh-border);"></div>
                <span class="px-3 small text-muted">or sign up with email & mobile</span>
                <div class="flex-grow-1" style="height:1px;background:var(--bh-border);"></div>
            </div>
        }

        <partial name="_ValidationSummary" />
        <form asp-action="Register" method="post">
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="FullName" class="form-label"></label>
                    <input asp-for="FullName" class="form-control" placeholder="John Doe" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label">Email <span class="text-danger">*</span></label>
                    <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="PhoneNumber" class="form-label">Mobile <span class="text-danger">*</span></label>
                    <input asp-for="PhoneNumber" class="form-control" placeholder="+91 98765 43210" />
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="City" class="form-label"></label>
                    <input asp-for="City" class="form-control" placeholder="Pune" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <input asp-for="ConfirmPassword" class="form-control" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <div class="p-3" style="background:var(--bh-bg);border-radius:12px;">
                        <div class="form-check m-0">
                            <input asp-for="IsBarber" class="form-check-input" id="isBarberCheck" />
                            <label asp-for="IsBarber" class="form-check-label fw-semibold">I'm a barber and want to list my shop</label>
                        </div>
                    </div>
                </div>
                <div id="barberFields" class="col-12" style="display:none">
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="ShopName" class="form-label"></label>
                            <input asp-for="ShopName" class="form-control" placeholder="The Sharp Edge" />
                        </div>
                        <div class="col-12">
                            <label asp-for="ShopDescription" class="form-label"></label>
                            <textarea asp-for="ShopDescription" class="form-control" rows="2" placeholder="Tell customers what makes your shop special..."></textarea>
                        </div>
                        <div class="col-12">
                            <label asp-for="Address" class="form-label"></label>
                            <input asp-for="Address" class="form-control" placeholder="123 MG Road" />
                        </div>
                    </div>
                </div>
            </div>
            <button class="btn btn-primary w-100 btn-lg mt-4">Create account</button>
        </form>
        <div class="mt-3 text-center text-muted small">
            Already have an account? <a asp-action="Login" class="text-coral text-decoration-none fw-semibold">Log in</a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const chk = document.getElementById('isBarberCheck');
        const fields = document.getElementById('barberFields');
        function toggle() { fields.style.display = chk.checked ? 'block' : 'none'; }
        chk.addEventListener('change', toggle); toggle();
    </script>
}
