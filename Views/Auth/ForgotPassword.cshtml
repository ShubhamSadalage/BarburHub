@model ForgotPasswordDto
@{ ViewData["Title"] = "Forgot Password"; }

<div class="auth-shell">
    <div class="auth-card" style="max-width:480px;">
        <div class="text-center mb-4">
            <div class="stat-icon coral mx-auto mb-3" style="width:64px;height:64px;font-size:1.6rem;"><i class="bi bi-key"></i></div>
            <h3>Forgot your password?</h3>
            <p class="text-muted">Enter your email and we'll send you a link to reset it.</p>
        </div>
        <partial name="_ValidationSummary" />
        <form asp-action="ForgotPassword" method="post">
            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <button class="btn btn-primary w-100 btn-lg">Send reset link</button>
        </form>
        <div class="mt-4 text-center">
            <a asp-action="Login" class="text-coral text-decoration-none small fw-semibold"><i class="bi bi-arrow-left me-1"></i>Back to login</a>
        </div>
    </div>
</div>
