@model ResetPasswordDto
@{ ViewData["Title"] = "Reset Password"; }

<div class="auth-shell">
    <div class="auth-card" style="max-width:480px;">
        <div class="text-center mb-4">
            <div class="stat-icon emerald mx-auto mb-3" style="width:64px;height:64px;font-size:1.6rem;"><i class="bi bi-shield-lock"></i></div>
            <h3>Reset your password</h3>
            <p class="text-muted">Choose a strong new password for your account.</p>
        </div>
        <partial name="_ValidationSummary" />
        <form asp-action="ResetPassword" method="post">
            <input asp-for="Email" type="hidden" />
            <input asp-for="Token" type="hidden" />
            <div class="mb-3">
                <label asp-for="Password" class="form-label">New password</label>
                <input asp-for="Password" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label">Confirm password</label>
                <input asp-for="ConfirmPassword" class="form-control" />
            </div>
            <button class="btn btn-primary w-100 btn-lg">Reset password</button>
        </form>
    </div>
</div>
