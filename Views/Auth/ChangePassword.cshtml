@model ChangePasswordDto
@{ ViewData["Title"] = "Change Password"; }

<div class="auth-shell">
    <div class="auth-card" style="max-width:480px;">
        <div class="text-center mb-4">
            <div class="stat-icon violet mx-auto mb-3" style="width:64px;height:64px;font-size:1.6rem;"><i class="bi bi-key-fill"></i></div>
            <h3>Change password</h3>
            <p class="text-muted">Keep your account secure.</p>
        </div>
        <partial name="_ValidationSummary" />
        <form asp-action="ChangePassword" method="post">
            <div class="mb-3">
                <label asp-for="CurrentPassword" class="form-label"></label>
                <input asp-for="CurrentPassword" class="form-control" />
                <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label"></label>
                <input asp-for="NewPassword" class="form-control" />
                <span asp-validation-for="NewPassword" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ConfirmNewPassword" class="form-label"></label>
                <input asp-for="ConfirmNewPassword" class="form-control" />
                <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
            </div>
            <button class="btn btn-primary w-100 btn-lg">Update password</button>
        </form>
    </div>
</div>
