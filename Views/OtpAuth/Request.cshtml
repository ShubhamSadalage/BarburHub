@model BarberHub.Web.Features.Auth.Controllers.OtpRequestDto
@{
    ViewData["Title"] = "Login with code";
    var emailEnabled = (bool)(ViewBag.EmailOtpEnabled ?? false);
    var smsEnabled = (bool)(ViewBag.SmsOtpEnabled ?? false);
    string placeholder = (emailEnabled, smsEnabled) switch
    {
        (true, true) => "you@example.com or +91 98765 43210",
        (true, false) => "you@example.com",
        (false, true) => "+91 98765 43210",
        _ => ""
    };
}

<div class="auth-shell">
    <div class="col-md-7 col-lg-5">
        <div class="auth-card">
            <h2 class="mb-1">Login with a code</h2>
            <p class="text-muted mb-4">
                @if (emailEnabled && smsEnabled) { <text>We'll send a one-time code to your email or phone.</text> }
                else if (emailEnabled) { <text>We'll send a one-time code to your email.</text> }
                else if (smsEnabled) { <text>We'll send a one-time code to your phone.</text> }
            </p>

            <partial name="_ValidationSummary" />
            <form asp-action="Request" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label asp-for="Recipient" class="form-label"></label>
                    <input asp-for="Recipient" class="form-control" autofocus
                           placeholder="@placeholder" />
                    <span asp-validation-for="Recipient" class="text-danger small"></span>
                </div>
                <button class="btn btn-primary w-100">Send code</button>
            </form>

            <hr class="my-4" />
            <div class="text-center">
                <a asp-controller="Auth" asp-action="Login" class="text-coral text-decoration-none fw-semibold">
                    <i class="bi bi-arrow-left me-1"></i>Back to password login
                </a>
            </div>
        </div>
    </div>
</div>
