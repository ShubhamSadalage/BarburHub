@{ ViewData["Title"] = "Privacy Policy"; }

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="bh-card p-5">
            <h2 class="mb-3">Privacy Policy</h2>
            <p class="text-muted">Last updated @DateTime.Now.ToString("MMMM yyyy")</p>
            <p>Barber Hub respects your privacy. Your data is used only to power your bookings, orders, and communications within the app — never sold to third parties.</p>
            <p>For questions or data deletion requests, contact us through the chat feature or your profile settings.</p>
        </div>
    </div>
</div>
