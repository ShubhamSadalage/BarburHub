@{ ViewData["Title"] = "Error"; }

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="bh-card p-5 text-center">
            <div class="stat-icon coral mx-auto mb-3" style="width:72px;height:72px;font-size:2rem;"><i class="bi bi-exclamation-triangle"></i></div>
            <h2>Something went wrong</h2>
            <p class="text-muted">We're sorry — an unexpected error occurred. Please try again later.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3"><i class="bi bi-arrow-left me-1"></i>Back to Home</a>
        </div>
    </div>
</div>
