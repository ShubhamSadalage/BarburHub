@model List<ChatContactDto>
@{ ViewData["Title"] = "Messages"; }

<div class="d-flex justify-content-between align-items-end mb-3 flex-wrap gap-2">
    <div>
        <h2 class="section-title">Messages</h2>
        <p class="section-subtitle mb-0">Your conversations with barbers and customers.</p>
    </div>
    @if (Model.Any())
    {
        <span class="badge bg-light text-dark px-3 py-2"><i class="bi bi-chat-dots me-1"></i>@Model.Count conversations</span>
    }
</div>

@if (!Model.Any())
{
    <div class="bh-card p-5 text-center">
        <div class="stat-icon violet mx-auto mb-3" style="width:64px;height:64px;font-size:1.6rem;"><i class="bi bi-chat-dots"></i></div>
        <h5>No conversations yet</h5>
        <p class="text-muted mb-3">Start a chat from a barber's details page.</p>
        <a asp-controller="Barbers" asp-action="Index" class="btn btn-primary">Find a barber</a>
    </div>
}
else
{
    <div class="bh-card p-0 overflow-hidden">
        <div class="d-flex flex-column">
            @foreach (var c in Model)
            {
                <a asp-action="Conversation" asp-route-otherUserId="@c.UserId"
                   class="d-flex align-items-center gap-3 p-3 text-decoration-none text-reset"
                   style="border-bottom:1px solid var(--bh-border); transition:background .15s ease;"
                   onmouseover="this.style.background='var(--bh-bg)'" onmouseout="this.style.background='transparent'">
                    @if (!string.IsNullOrEmpty(c.ProfileImageUrl))
                    {
                        <img src="@c.ProfileImageUrl" style="width:52px;height:52px;border-radius:50%;object-fit:cover;flex-shrink:0;" />
                    }
                    else
                    {
                        <div class="bh-avatar" style="width:52px;height:52px;font-size:1.1rem;flex-shrink:0;">@(string.IsNullOrEmpty(c.FullName) ? "U" : c.FullName.Substring(0,1).ToUpper())</div>
                    }
                    <div class="flex-grow-1 overflow-hidden">
                        <div class="d-flex justify-content-between align-items-baseline">
                            <strong class="text-truncate">@c.FullName</strong>
                            <small class="text-muted ms-2 flex-shrink-0">@(c.LastMessageAt?.ToString("MMM dd · HH:mm") ?? "")</small>
                        </div>
                        <div class="small text-muted text-truncate">@c.LastMessage</div>
                    </div>
                    @if (c.UnreadCount > 0)
                    {
                        <span class="badge rounded-pill" style="background:var(--bh-primary)!important;color:#fff!important;min-width:24px;height:24px;display:flex;align-items:center;justify-content:center;">@c.UnreadCount</span>
                    }
                </a>
            }
        </div>
    </div>
}
