@model List<BookingListItemDto>
@{ ViewData["Title"] = "My Bookings"; }

<div class="d-flex justify-content-between align-items-end mb-3 flex-wrap gap-2">
    <div>
        <h2 class="section-title">My Bookings</h2>
        <p class="section-subtitle mb-0">Track all your past and upcoming appointments.</p>
    </div>
    <a asp-controller="Barbers" asp-action="Index" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i> New Booking</a>
</div>

@if (!Model.Any())
{
    <div class="bh-card p-5 text-center">
        <div class="stat-icon coral mx-auto mb-3" style="width:64px;height:64px;font-size:1.6rem;"><i class="bi bi-calendar-x"></i></div>
        <h5>No bookings yet</h5>
        <p class="text-muted mb-3">Find a barber to schedule your first appointment.</p>
        <a asp-controller="Barbers" asp-action="Index" class="btn btn-primary">Find a barber</a>
    </div>
}
else
{
    <div class="bh-card p-0 overflow-hidden">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Shop</th>
                        <th>Service</th>
                        <th>Date & Time</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th class="pe-4 text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var b in Model)
                {
                    <tr>
                        <td class="ps-4"><strong>@b.ShopName</strong></td>
                        <td>@b.ServiceName</td>
                        <td>
                            <div class="fw-semibold">@b.AppointmentDate.ToString("ddd, MMM dd")</div>
                            <small class="text-muted">@b.StartTime.ToString("HH:mm") – @b.EndTime.ToString("HH:mm")</small>
                        </td>
                        <td class="fw-semibold">₹@b.TotalAmount</td>
                        <td>
                            @{
                                var badge = b.Status switch {
                                    BookingStatus.Pending => "bg-warning",
                                    BookingStatus.Accepted => "bg-success",
                                    BookingStatus.Rejected => "bg-danger",
                                    BookingStatus.Completed => "bg-primary",
                                    BookingStatus.Cancelled => "bg-secondary",
                                    _ => "bg-light"
                                };
                            }
                            <span class="badge @badge">@b.Status</span>
                            @if (!string.IsNullOrEmpty(b.RejectionReason))
                            {
                                <div class="small text-muted mt-1">Reason: @b.RejectionReason</div>
                            }
                        </td>
                        <td class="pe-4 text-end">
                            @if (b.Status == BookingStatus.Pending || b.Status == BookingStatus.Accepted)
                            {
                                <form asp-action="Cancel" asp-route-id="@b.Id" method="post" onsubmit="return confirm('Cancel this booking?');" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-danger">Cancel</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}
