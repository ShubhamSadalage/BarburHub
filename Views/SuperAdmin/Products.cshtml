@model List<BarberHub.Web.Domain.Entities.Product>
@{ ViewData["Title"] = "Marketplace Products"; }

<div class="d-flex justify-content-between align-items-end mb-3 flex-wrap gap-2">
    <div>
        <h2 class="section-title">Marketplace Products</h2>
        <p class="section-subtitle mb-0">Platform-owned products available to all customers.</p>
    </div>
    <a asp-action="CreateProduct" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Add Product</a>
</div>

@if (!Model.Any())
{
    <div class="bh-card p-5 text-center">
        <div class="stat-icon violet mx-auto mb-3" style="width:64px;height:64px;font-size:1.6rem;"><i class="bi bi-bag-plus"></i></div>
        <h5>No marketplace products yet</h5>
        <p class="text-muted mb-3">Add your first marketplace product to get started.</p>
        <a asp-action="CreateProduct" class="btn btn-primary">Add Product</a>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var p in Model)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <div class="product-card">
                    <div class="product-img-wrap">
                        @if (p.DiscountPercentage > 0)
                        {
                            <span class="badge-discount-floating">-@p.DiscountPercentage%</span>
                        }
                        @if (!string.IsNullOrEmpty(p.ImageUrl))
                        {
                            <img src="@p.ImageUrl" alt="@p.Name" />
                        }
                        else
                        {
                            <i class="bi bi-image text-muted" style="font-size:3rem;"></i>
                        }
                    </div>
                    <div class="product-body">
                        <h6 class="product-name">@p.Name</h6>
                        <div class="product-meta">@p.Category · Stock: @p.StockQuantity</div>
                        <div class="product-price-row">
                            @if (p.DiscountPercentage > 0)
                            {
                                <span class="price-final">₹@p.EffectivePrice</span>
                                <span class="price-original">₹@p.Price</span>
                            }
                            else
                            {
                                <span class="price-final">₹@p.Price</span>
                            }
                            <span class="badge @(p.IsActive ? "bg-success" : "bg-secondary") ms-auto">
                                @(p.IsActive ? "Active" : "Hidden")
                            </span>
                        </div>
                        <div class="d-flex gap-2 mt-2">
                            <a asp-action="EditProduct" asp-route-id="@p.Id" class="btn btn-light btn-sm flex-grow-1"><i class="bi bi-pencil me-1"></i>Edit</a>
                            <form asp-action="DeleteProduct" method="post" class="flex-shrink-0" onsubmit="return confirm('Delete this product?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@p.Id" />
                                <button class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
