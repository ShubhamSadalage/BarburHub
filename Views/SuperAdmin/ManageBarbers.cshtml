@using BarberHub.Web.Domain.Entities
@{
    ViewData["Title"] = "Manage Barbers";
    var barbers = ViewBag.Barbers as IEnumerable<dynamic> ?? new List<dynamic>();
}

<div class="d-flex justify-content-between align-items-end mb-3 flex-wrap gap-2">
    <div>
        <h2 class="section-title">Manage Barbers</h2>
        <p class="section-subtitle mb-0">All barber accounts on the platform.</p>
    </div>
    <span class="badge bg-light text-dark px-3 py-2"><i class="bi bi-shop me-1"></i>@barbers.Count() total</span>
</div>

<div class="bh-card p-0 overflow-hidden">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th class="ps-4">Shop</th>
                    <th>Owner</th>
                    <th>Contact</th>
                    <th>Approval</th>
                    <th>Status</th>
                    <th class="pe-4 text-end">Action</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var b in barbers)
            {
                <tr>
                    <td class="ps-4">
                        <div class="fw-semibold">@(b.ShopName ?? "—")</div>
                        <small class="text-muted">@b.City</small>
                    </td>
                    <td>@b.FullName</td>
                    <td><div>@b.Email</div><small class="text-muted">@b.PhoneNumber</small></td>
                    <td>
                        @{
                            BarberApprovalStatus s = (BarberApprovalStatus)b.ApprovalStatus;
                            var (cls, lbl) = s switch
                            {
                                BarberApprovalStatus.Approved => ("bg-success", "Approved"),
                                BarberApprovalStatus.Pending => ("bg-warning", "Pending"),
                                BarberApprovalStatus.Rejected => ("bg-danger", "Rejected"),
                                _ => ("bg-secondary", "—")
                            };
                        }
                        <span class="badge @cls">@lbl</span>
                    </td>
                    <td>
                        @if (b.IsDeleted)
                        { <span class="badge bg-danger">Deleted</span> }
                        else if (b.IsActive)
                        { <span class="badge bg-success">Active</span> }
                        else
                        { <span class="badge bg-secondary">Inactive</span> }
                    </td>
                    <td class="pe-4 text-end">
                        @if (b.IsDeleted)
                        {
                            <form asp-action="RestoreBarber" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@b.Id" />
                                <button class="btn btn-light btn-sm"><i class="bi bi-arrow-counterclockwise me-1"></i>Restore</button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="DeleteBarber" method="post" class="d-inline" onsubmit="return confirm('Delete this barber? Their data is preserved but they cannot log in.');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@b.Id" />
                                <button class="btn btn-outline-danger btn-sm"><i class="bi bi-trash me-1"></i>Delete</button>
                            </form>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
