@{ ViewData["Title"] = "SuperAdmin Dashboard"; }

<div class="d-flex justify-content-between align-items-end mb-4 flex-wrap gap-2">
    <div>
        <h2 class="section-title">Platform Overview</h2>
        <p class="section-subtitle mb-0">All barbers, customers, and marketplace at a glance.</p>
    </div>
    <span class="badge bg-light text-dark px-3 py-2"><i class="bi bi-shield-check me-1"></i>SuperAdmin</span>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon coral"><i class="bi bi-hourglass-split"></i></div>
            <div>
                <div class="stat-value">@ViewBag.PendingBarbers</div>
                <div class="stat-label">Pending Approvals</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon emerald"><i class="bi bi-check2-circle"></i></div>
            <div>
                <div class="stat-value">@ViewBag.ApprovedBarbers</div>
                <div class="stat-label">Approved Barbers</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon sky"><i class="bi bi-people"></i></div>
            <div>
                <div class="stat-value">@ViewBag.TotalUsers</div>
                <div class="stat-label">Total Customers</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon violet"><i class="bi bi-bag"></i></div>
            <div>
                <div class="stat-value">@ViewBag.MarketplaceProducts</div>
                <div class="stat-label">Marketplace Products</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon amber"><i class="bi bi-shop"></i></div>
            <div>
                <div class="stat-value">@ViewBag.BarberProducts</div>
                <div class="stat-label">Barber Products</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon coral"><i class="bi bi-calendar-check"></i></div>
            <div>
                <div class="stat-value">@ViewBag.TotalBookings</div>
                <div class="stat-label">Total Bookings</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon emerald"><i class="bi bi-receipt"></i></div>
            <div>
                <div class="stat-value">@ViewBag.TotalOrders</div>
                <div class="stat-label">Total Orders</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon violet"><i class="bi bi-shop-window"></i></div>
            <div>
                <div class="stat-value">@ViewBag.TotalBarbers</div>
                <div class="stat-label">All Barbers</div>
            </div>
        </div>
    </div>
</div>

<h4 class="mb-3">Quick Actions</h4>
<div class="row g-3">
    <div class="col-md-4">
        <a asp-action="Approvals" class="bh-card bh-card-hover p-4 d-block text-decoration-none text-reset h-100">
            <div class="d-flex align-items-start gap-3">
                <div class="stat-icon coral"><i class="bi bi-check2-square"></i></div>
                <div>
                    <h5 class="mb-1">Barber Approvals</h5>
                    <p class="text-muted mb-0 small">Review and approve new barber registrations.</p>
                </div>
            </div>
            <div class="text-coral fw-semibold small mt-3">Open <i class="bi bi-arrow-right"></i></div>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-action="Products" class="bh-card bh-card-hover p-4 d-block text-decoration-none text-reset h-100">
            <div class="d-flex align-items-start gap-3">
                <div class="stat-icon violet"><i class="bi bi-bag"></i></div>
                <div>
                    <h5 class="mb-1">Marketplace Products</h5>
                    <p class="text-muted mb-0 small">Manage platform-wide products.</p>
                </div>
            </div>
            <div class="text-coral fw-semibold small mt-3">Open <i class="bi bi-arrow-right"></i></div>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-controller="Admin" asp-action="Users" class="bh-card bh-card-hover p-4 d-block text-decoration-none text-reset h-100">
            <div class="d-flex align-items-start gap-3">
                <div class="stat-icon sky"><i class="bi bi-people"></i></div>
                <div>
                    <h5 class="mb-1">All Users</h5>
                    <p class="text-muted mb-0 small">Browse customers on the platform.</p>
                </div>
            </div>
            <div class="text-coral fw-semibold small mt-3">Open <i class="bi bi-arrow-right"></i></div>
        </a>
    </div>
</div>
