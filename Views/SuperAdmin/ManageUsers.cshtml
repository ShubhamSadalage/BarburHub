@{
    ViewData["Title"] = "Manage Users";
    var users = ViewBag.Users as IEnumerable<dynamic> ?? new List<dynamic>();
}

<div class="d-flex justify-content-between align-items-end mb-3 flex-wrap gap-2">
    <div>
        <h2 class="section-title">Manage Users</h2>
        <p class="section-subtitle mb-0">All customers on the platform.</p>
    </div>
    <span class="badge bg-light text-dark px-3 py-2"><i class="bi bi-people me-1"></i>@users.Count() total</span>
</div>

<div class="bh-card p-0 overflow-hidden">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th class="ps-4">Name</th>
                    <th>Contact</th>
                    <th>City</th>
                    <th>Joined</th>
                    <th>Status</th>
                    <th class="pe-4 text-end">Action</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var u in users)
            {
                <tr>
                    <td class="ps-4 fw-semibold">@u.FullName</td>
                    <td><div>@u.Email</div><small class="text-muted">@u.PhoneNumber</small></td>
                    <td>@(u.City ?? "—")</td>
                    <td class="small">@u.CreatedAt.ToString("MMM dd, yyyy")</td>
                    <td>
                        @if (u.IsDeleted)
                        { <span class="badge bg-danger">Deleted</span> }
                        else if (u.IsActive)
                        { <span class="badge bg-success">Active</span> }
                        else
                        { <span class="badge bg-secondary">Inactive</span> }
                    </td>
                    <td class="pe-4 text-end">
                        @if (u.IsDeleted)
                        {
                            <form asp-action="RestoreUser" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@u.Id" />
                                <button class="btn btn-light btn-sm"><i class="bi bi-arrow-counterclockwise me-1"></i>Restore</button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="DeleteUser" method="post" class="d-inline" onsubmit="return confirm('Delete this user? Their data is preserved but they cannot log in.');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@u.Id" />
                                <button class="btn btn-outline-danger btn-sm"><i class="bi bi-trash me-1"></i>Delete</button>
                            </form>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
