<script>
// ---------- Toaster (auto-dismiss) ----------
window.bhToast = function(message, kind /* 'success' | 'error' | 'info' */) {
    if (!message) return;
    kind = kind || 'info';
    const container = document.getElementById('bhToastContainer');
    if (!container) return;
    const el = document.createElement('div');
    el.className = 'bh-toast bh-toast-' + kind;
    const icon = kind === 'success' ? 'bi-check-circle' : (kind === 'error' ? 'bi-exclamation-circle' : 'bi-info-circle');
    el.innerHTML =
        '<i class="bi ' + icon + ' bh-toast-icon"></i>' +
        '<div class="bh-toast-body"></div>' +
        '<button class="bh-toast-close" aria-label="Close">&times;</button>';
    el.querySelector('.bh-toast-body').textContent = message;
    el.querySelector('.bh-toast-close').addEventListener('click', () => dismiss(el));
    container.appendChild(el);
    const timer = setTimeout(() => dismiss(el), 4000);
    function dismiss(node) {
        clearTimeout(timer);
        if (!node.parentNode) return;
        node.classList.add('fade-out');
        setTimeout(() => node.remove(), 250);
    }
};

// Auto-fire from TempData (server-rendered into JS object below)
(function() {
    @if (TempData["Success"] is not null)
    {
        <text>window.bhToast(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["Success"]?.ToString() ?? "")), 'success');</text>
    }
    @if (TempData["Error"] is not null)
    {
        <text>window.bhToast(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["Error"]?.ToString() ?? "")), 'error');</text>
    }
})();
</script>

@if (isLoggedIn)
{
<script>
(function() {
    const badge = document.getElementById('bhBellBadge');
    const badgeMobile = document.getElementById('bhBellBadgeMobile');
    const list = document.getElementById('bhNotifList');
    const listMobile = document.querySelector('.bh-notif-list-mobile');
    const markAllBtns = [
        document.getElementById('bhMarkAllRead'),
        ...document.querySelectorAll('.bh-mark-all-read')
    ].filter(Boolean);
    const tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');
    const csrf = tokenEl ? tokenEl.value : '';

    function timeAgo(dateStr) {
        const d = new Date(dateStr); const s = (Date.now() - d.getTime()) / 1000;
        if (s < 60) return 'just now';
        if (s < 3600) return Math.floor(s/60) + 'm';
        if (s < 86400) return Math.floor(s/3600) + 'h';
        return Math.floor(s/86400) + 'd';
    }
    function escapeHtml(t) { return String(t).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }

    function setBadge(n) {
        [badge, badgeMobile].forEach(b => {
            if (!b) return;
            if (n > 0) { b.classList.add('show'); b.textContent = n > 9 ? '9+' : n; }
            else { b.classList.remove('show'); }
        });
    }

    function buildHtml(items) {
        if (!items || items.length === 0) {
            return '<div class="text-muted text-center py-4 small">You\'re all caught up.</div>';
        }
        return items.map(n => `
            <a href="${n.linkUrl || '#'}" data-id="${n.id}" class="bh-notif-item text-decoration-none text-reset">
                <div class="bh-notif-icon"><i class="bi bi-bell"></i></div>
                <div class="flex-grow-1">
                    <div class="fw-semibold">${escapeHtml(n.title)}</div>
                    <div class="text-muted small">${escapeHtml(n.message)}</div>
                    <div class="text-muted" style="font-size:.7rem;margin-top:2px;">${timeAgo(n.createdAt)}</div>
                </div>
            </a>`).join('');
    }

    function attachClickHandlers(container) {
        container.querySelectorAll('.bh-notif-item').forEach(a => {
            a.addEventListener('click', async (ev) => {
                const id = a.getAttribute('data-id');
                const href = a.getAttribute('href') || '#';
                if (href === '#') {
                    ev.preventDefault();
                    await markRead(id);
                    a.classList.add('fade-out');
                    setTimeout(() => a.remove(), 350);
                    bumpBadgeDown();
                    return;
                }
                ev.preventDefault();
                markRead(id).finally(() => { window.location.href = href; });
            });
        });
    }

    function renderNotifs(items, unread) {
        setBadge(unread);
        const html = buildHtml(items);
        if (list) { list.innerHTML = html; attachClickHandlers(list); }
        if (listMobile) { listMobile.innerHTML = html; attachClickHandlers(listMobile); }
    }

    function bumpBadgeDown() {
        const cur = parseInt((badge?.textContent) || '0', 10) || 0;
        setBadge(Math.max(0, cur - 1));
        const remaining = (list?.querySelectorAll('.bh-notif-item:not(.fade-out)').length) || 0;
        if (remaining === 0 && list) {
            setTimeout(() => { list.innerHTML = '<div class="text-muted text-center py-4 small">You\'re all caught up.</div>'; }, 350);
        }
    }

    async function markRead(id) {
        try {
            const fd = new FormData();
            fd.append('id', id);
            if (csrf) fd.append('__RequestVerificationToken', csrf);
            await fetch('/Notifications/MarkRead', { method: 'POST', credentials: 'same-origin', body: fd });
        } catch (e) { /* ignore */ }
    }

    async function loadNotifs() {
        try {
            const r = await fetch('/Notifications/Recent', { credentials: 'same-origin' });
            const data = await r.json();
            renderNotifs(data.items, data.unreadCount);
        } catch (e) { /* ignore */ }
    }

    markAllBtns.forEach(btn => btn.addEventListener('click', async (e) => {
        e.preventDefault();
        const fd = new FormData();
        if (csrf) fd.append('__RequestVerificationToken', csrf);
        await fetch('/Notifications/MarkAllRead', { method: 'POST', credentials: 'same-origin', body: fd });
        loadNotifs();
    }));

    loadNotifs();

    try {
        const conn = new signalR.HubConnectionBuilder().withUrl('/hubs/notifications').withAutomaticReconnect().build();
        conn.on('ReceiveNotification', (n) => {
            if (window.bhToast) window.bhToast(n.title + ' — ' + n.message, 'info');
            loadNotifs();
        });
        conn.start().catch(() => {});
    } catch (e) { /* ignore */ }
})();
</script>
}

