            .bh-notif-panel { min-width: calc(100vw - 32px); max-width: calc(100vw - 32px); }

            .bh-toast-container { top: 70px; right: 12px; left: 12px; max-width: none; }
            .bh-toast { min-width: 0; max-width: none; }

            /* Footer not sticky on mobile (tab bar takes over) */
            .bh-footer { position: static; }
        }

        @@media (max-width: 360px) {
            body { font-size: 14px; }
            .bh-hero { padding: 28px 18px; }
            .bh-hero h1 { font-size: 1.6rem; }
        }
    </style>
