            .stat-value { font-size: 1.3rem; }
            .btn { padding: .6rem 1.1rem; }
            .btn-sm { padding: .45rem .9rem; }
            .bh-card, .card { border-radius: 14px; }
            .container { padding-left: 14px; padding-right: 14px; }

            .bh-brand span:last-child { display: none; }

            .bh-tabbar { display: flex; }
            main.bh-main { padding-bottom: calc(var(--bh-tabbar-h) + 16px) !important; }

            .bh-cart-pill-mobile-hide { display: none !important; }

            .bh-avatar-btn span:not(.bh-avatar) { display: none; }
