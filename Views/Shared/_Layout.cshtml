@if (isLoggedIn)
{
<script>
// Web Push subscription — runs once after we have a SW registration AND a VAPID key.
(async function() {
    if (!('serviceWorker' in navigator) || !('PushManager' in window)) return;
    try {
        const reg = await navigator.serviceWorker.ready;

        const keyResp = await fetch('/Push/VapidKey', { credentials: 'same-origin' });
        const cfg = await keyResp.json();
        if (!cfg.configured) return;  // Web Push not enabled server-side

        // Permission — only ask once after a user gesture or proactively on logged-in pages
        let permission = Notification.permission;
        if (permission === 'default') {
            permission = await Notification.requestPermission();
        }
        if (permission !== 'granted') return;

        // Try to reuse an existing subscription, else create a new one
        let sub = await reg.pushManager.getSubscription();
        if (!sub) {
            sub = await reg.pushManager.subscribe({
                userVisibleOnly: true,
                applicationServerKey: urlBase64ToUint8Array(cfg.publicKey)
            });
        }

        const json = sub.toJSON();
        const fd = new FormData();
        fd.append('Endpoint', json.endpoint);
        fd.append('P256dh', json.keys.p256dh);
        fd.append('Auth', json.keys.auth);
        const t = document.querySelector('input[name="__RequestVerificationToken"]');
        if (t) fd.append('__RequestVerificationToken', t.value);
        await fetch('/Push/Subscribe', { method: 'POST', credentials: 'same-origin', body: fd });
    } catch (e) { /* ignore */ }
})();

function urlBase64ToUint8Array(base64String) {
    const padding = '='.repeat((4 - base64String.length % 4) % 4);
    const base64 = (base64String + padding).replace(/-/g, '+').replace(/_/g, '/');
    const raw = atob(base64);
    const out = new Uint8Array(raw.length);
    for (let i = 0; i < raw.length; ++i) out[i] = raw.charCodeAt(i);
    return out;
}
</script>
}

