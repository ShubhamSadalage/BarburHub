@model BarberDetailsDto
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@{ ViewData["Title"] = Model.ShopName; }

<div class="row g-4">
    <div class="col-lg-5">
        <div class="bh-card overflow-hidden">
            @if (!string.IsNullOrEmpty(Model.ProfileImageUrl))
            {
                <img src="@Model.ProfileImageUrl" style="height:280px;width:100%;object-fit:cover;" />
            }
            else
            {
                <div class="d-flex align-items-center justify-content-center" style="height:280px;background:linear-gradient(135deg, var(--bh-primary), var(--bh-accent));color:#fff;">
                    <i class="bi bi-scissors" style="font-size:4rem;"></i>
                </div>
            }
            <div class="p-4">
                <h3 class="mb-1">@Model.ShopName</h3>
                <p class="text-muted mb-3">by @Model.FullName</p>
                @if (!string.IsNullOrEmpty(Model.ShopDescription))
                {
                    <p class="mb-3">@Model.ShopDescription</p>
                }

                <div class="d-flex flex-column gap-2 small">
                    <div><i class="bi bi-geo-alt text-coral me-2"></i>@Model.Address, @Model.City</div>
                    @if (!string.IsNullOrEmpty(Model.PhoneNumber))
                    {
                        <div><i class="bi bi-telephone text-coral me-2"></i>@Model.PhoneNumber</div>
                    }
                    @if (Model.OpeningTime.HasValue && Model.ClosingTime.HasValue)
                    {
                        <div><i class="bi bi-clock text-coral me-2"></i>@Model.OpeningTime?.ToString("hh:mm tt") – @Model.ClosingTime?.ToString("hh:mm tt")</div>
                    }
                    @if (Model.WeeklyHoliday.HasValue)
                    {
                        <div class="text-warning"><i class="bi bi-calendar-x me-2"></i>Closed on @Model.WeeklyHoliday</div>
                    }
                </div>

                @if (SignInManager.IsSignedIn(User) && User.IsInRole(AppRoles.User))
                {
                    <a asp-controller="Chat" asp-action="Conversation" asp-route-otherUserId="@Model.Id" class="btn btn-outline-secondary w-100 mt-4">
                        <i class="bi bi-chat-dots me-1"></i> Chat with Barber
                    </a>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="bh-card p-4 mb-4">
            <h4 class="mb-3"><i class="bi bi-calendar-plus text-coral me-2"></i>Book an Appointment</h4>
            @if (!SignInManager.IsSignedIn(User))
            {
                <div class="alert alert-warning mb-0">Please <a asp-controller="Auth" asp-action="Login" class="fw-semibold">log in</a> to book an appointment.</div>
            }
            else if (!User.IsInRole(AppRoles.User))
            {
                <div class="alert alert-info mb-0">Only customers can book appointments.</div>
            }
            else
            {
                <form asp-controller="Bookings" asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="BarberId" value="@Model.Id" />
                    <div class="mb-3">
                        <label class="form-label">Choose a service</label>
                        <select name="ServiceId" id="serviceSelect" class="form-select" required>
                            <option value="">-- select service --</option>
                            @foreach (var s in Model.Services)
                            {
                                <option value="@s.Id" data-duration="@s.DurationMinutes" data-price="@s.Price">
                                    @s.Name — ₹@s.Price (@s.DurationMinutes min)
                                </option>
                            }
                        </select>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Date</label>
                            <input type="date" id="dateInput" class="form-control"
                                   min="@DateTime.Today.ToString("yyyy-MM-dd")"
                                   max="@DateTime.Today.AddDays(60).ToString("yyyy-MM-dd")" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Available time slots</label>
                            <div id="slotsContainer" class="d-flex flex-wrap gap-2" style="min-height:42px;align-items:center;">
                                <span class="text-muted small">Pick a service & date first</span>
                            </div>
                            <input type="hidden" name="StartTime" id="startTimeHidden" required />
                        </div>
                    </div>
                    <div class="mt-3">
                        <label class="form-label">Date (booking)</label>
                        <input type="date" name="AppointmentDate" id="appointmentDateMirror" class="form-control" required readonly style="background:var(--bh-bg);" />
                    </div>
                    <div class="mt-3">
                        <label class="form-label">Notes (optional)</label>
                        <textarea name="Notes" class="form-control" rows="2" placeholder="Any preferences or requests..."></textarea>
                    </div>
                    <button class="btn btn-primary mt-3 w-100 btn-lg" id="bookBtn" disabled>Confirm Booking <i class="bi bi-arrow-right ms-1"></i></button>
                </form>
            }
        </div>

        <div class="bh-card p-4">
            <h5 class="mb-3"><i class="bi bi-list-check text-coral me-2"></i>Services Offered</h5>
            <div class="d-flex flex-column gap-3">
                @foreach (var s in Model.Services)
                {
                    <div class="d-flex justify-content-between align-items-start py-2" style="border-bottom:1px solid var(--bh-border);">
                        <div>
                            <strong>@s.Name</strong>
                            <div class="small text-muted">@s.Description</div>
                        </div>
                        <div class="text-end">
                            <div class="fw-bold text-coral">₹@s.Price</div>
                            <div class="small text-muted">@s.DurationMinutes min</div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const serviceSel = document.getElementById('serviceSelect');
    const dateInput = document.getElementById('dateInput');
    const dateMirror = document.getElementById('appointmentDateMirror');
    const slotsContainer = document.getElementById('slotsContainer');
    const startTimeHidden = document.getElementById('startTimeHidden');
    const bookBtn = document.getElementById('bookBtn');
    const barberId = '@Model.Id';

    dateInput?.addEventListener('change', () => { if (dateMirror) dateMirror.value = dateInput.value; });

    async function loadSlots() {
        if (!serviceSel?.value || !dateInput?.value) {
            slotsContainer.innerHTML = '<span class="text-muted small">Pick a service & date first</span>';
            startTimeHidden.value = ''; bookBtn.disabled = true; return;
        }
        slotsContainer.innerHTML = '<span class="text-muted small">Loading slots…</span>';
        const url = `/Barbers/AvailableSlots?barberId=${barberId}&date=${dateInput.value}&serviceId=${serviceSel.value}`;
        try {
            const res = await fetch(url);
            const data = await res.json();
            if (data.isHoliday) {
                slotsContainer.innerHTML = '<span class="badge bg-warning">Barber is closed on this day</span>';
                startTimeHidden.value = ''; bookBtn.disabled = true;
            } else if (data.isLeaveDay) {
                slotsContainer.innerHTML = '<span class="badge bg-warning">Barber is on leave this day</span>';
                startTimeHidden.value = ''; bookBtn.disabled = true;
            } else if (!data.availableSlots || data.availableSlots.length === 0) {
                slotsContainer.innerHTML = '<span class="badge bg-secondary">No slots available</span>';
                startTimeHidden.value = ''; bookBtn.disabled = true;
            } else {
                slotsContainer.innerHTML = '';
                data.availableSlots.forEach(s => {
                    const pill = document.createElement('span');
                    pill.className = 'slot-pill';
                    pill.textContent = s.substring(0,5);
                    pill.dataset.value = s;
                    pill.onclick = () => {
                        document.querySelectorAll('.slot-pill').forEach(p => p.classList.remove('selected'));
                        pill.classList.add('selected');
                        startTimeHidden.value = s;
                        bookBtn.disabled = false;
                    };
                    slotsContainer.appendChild(pill);
                });
                startTimeHidden.value = ''; bookBtn.disabled = true;
            }
        } catch (e) {
            slotsContainer.innerHTML = '<span class="text-danger small">Failed to load slots</span>';
            bookBtn.disabled = true;
        }
    }
    serviceSel?.addEventListener('change', loadSlots);
    dateInput?.addEventListener('change', loadSlots);
</script>
}
