@model List<BarberListItemDto>
@{
    ViewData["Title"] = "Find Barbers";
    var search = ViewBag.Search as BarberSearchDto ?? new BarberSearchDto();
}

<div class="d-flex justify-content-between align-items-end mb-3 flex-wrap gap-2">
    <div>
        <h2 class="section-title">Find Barbers</h2>
        <p class="section-subtitle mb-0">Discover top-rated grooming experts near you.</p>
    </div>
    <span class="badge bg-light text-dark px-3 py-2"><i class="bi bi-shop me-1"></i>@Model.Count results</span>
</div>

<div class="mb-4">
    <partial name="Maps/_BarbersMap" model="@Model" />
</div>

<div class="bh-card p-4 mb-4">
    <form method="get" class="row g-3 align-items-end">
        <div class="col-md-9">
            <label class="form-label"><i class="bi bi-geo me-1"></i>Search a city or area</label>
            <input name="City" id="bhBarberCity" value="@search.City" class="form-control"
                   placeholder="Pune, Andheri, Whitefield…" />
        </div>
        <input name="Latitude" id="bhLat" type="hidden" value="@search.Latitude" />
        <input name="Longitude" id="bhLng" type="hidden" value="@search.Longitude" />
        <input name="RadiusKm" type="hidden" value="@(search.RadiusKm > 0 ? search.RadiusKm : 25)" />
        <div class="col-md-3 d-flex flex-wrap gap-2">
            <button class="btn btn-primary flex-grow-1"><i class="bi bi-search me-1"></i> Search</button>
            <button type="button" class="btn btn-outline-secondary flex-grow-1" id="bhUseMyLoc">
                <i class="bi bi-geo-alt me-1"></i> Use my location
            </button>
        </div>
    </form>
</div>

@if (!Model.Any())
{
    <div class="bh-card p-5 text-center">
        <div class="stat-icon amber mx-auto mb-3" style="width:64px;height:64px;font-size:1.6rem;"><i class="bi bi-search"></i></div>
        <h5>No barbers found</h5>
        <p class="text-muted mb-0">Try a different city or wider radius.</p>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var b in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="barber-card">
                    <div class="barber-cover"></div>
                    <div class="px-4 pb-4">
                        <div class="barber-avatar">
                            @if (!string.IsNullOrEmpty(b.ProfileImageUrl))
                            {
                                <img src="@b.ProfileImageUrl" style="width:100%;height:100%;border-radius:50%;object-fit:cover;" />
                            }
                            else
                            {
                                <i class="bi bi-scissors fs-3"></i>
                            }
                        </div>
                        <h5 class="mt-3 mb-1">@b.ShopName</h5>
                        <div class="text-muted small mb-3">by @b.FullName</div>
                        <div class="text-muted small mb-2"><i class="bi bi-geo-alt me-1"></i>@b.City @(b.DistanceKm.HasValue ? $"· {b.DistanceKm.Value:F1} km away" : "")</div>
                        @if (!string.IsNullOrEmpty(b.Address))
                        {
                            <div class="text-muted small mb-3" style="min-height:1.5em;">@b.Address</div>
                        }
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="badge bg-light text-dark"><i class="bi bi-scissors me-1"></i>@b.ServiceCount services</span>
                            @if (b.MinPrice.HasValue)
                            {
                                <span class="small fw-semibold text-coral">From ₹@b.MinPrice</span>
                            }
                        </div>
                        <a asp-action="Details" asp-route-id="@b.Id" class="btn btn-primary w-100">View & Book <i class="bi bi-arrow-right ms-1"></i></a>
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <script>
        (function() {
            const btn = document.getElementById('bhUseMyLoc');
            if (!btn || !navigator.geolocation) { if (btn) btn.style.display='none'; return; }
            btn.addEventListener('click', function() {
                if (window.bhToast) window.bhToast('Getting your location…', 'info');
                navigator.geolocation.getCurrentPosition(
                    p => {
                        document.getElementById('bhLat').value = p.coords.latitude.toFixed(6);
                        document.getElementById('bhLng').value = p.coords.longitude.toFixed(6);
                        btn.closest('form').submit();
                    },
                    err => { if (window.bhToast) window.bhToast('Location unavailable: ' + err.message, 'error'); },
                    { enableHighAccuracy: true, timeout: 10000, maximumAge: 60000 }
                );
            });
        })();
    </script>
}
